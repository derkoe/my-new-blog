---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Christian Köberl – Software Developer">
	<section class="hero">
		<h1>Hi, I'm Christian Köberl 👋</h1>
		<p class="tagline">Software Developer passionate about building great things with code.</p>
		<a href="/about" class="btn">About me →</a>
	</section>
</Layout>

<style>
	.hero {
		padding: 4rem 0 2rem;
		text-align: center;
	}

	h1 {
		font-size: 2.5rem;
		margin: 0 0 1rem;
		color: #1a1a2e;
	}

	.tagline {
		font-size: 1.2rem;
		color: #4b5563;
		margin: 0 0 2rem;
	}

	.btn {
		display: inline-block;
		padding: 0.75rem 1.5rem;
		background: linear-gradient(83.21deg, #3245ff 0%, #bc52ee 100%);
		color: #fff;
		text-decoration: none;
		border-radius: 8px;
		font-weight: 600;
		transition: opacity 0.2s;
	}

	.btn:hover {
		opacity: 0.85;
	}
</style>
