---
interface Props {
	title?: string;
}
const { title = "Christian Köberl – Software Developer" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header>
			<nav>
				<a href="/" class="site-title">Christian Köberl</a>
				<ul>
					<li><a href="/">Home</a></li>
					<li><a href="/about">About</a></li>
				</ul>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer>
			<p>&copy; {new Date().getFullYear()} Christian Köberl</p>
		</footer>
	</body>
</html>

<style>
	*, *::before, *::after {
		box-sizing: border-box;
	}

	html, body {
		margin: 0;
		padding: 0;
		font-family: Inter, Roboto, "Helvetica Neue", Arial, sans-serif;
		color: #1a1a2e;
		background: #f9fafb;
		min-height: 100%;
	}

	header {
		background: #fff;
		border-bottom: 1px solid #e5e7eb;
		padding: 0 2rem;
	}

	nav {
		max-width: 800px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 60px;
	}

	.site-title {
		font-weight: 700;
		font-size: 1.1rem;
		color: #1a1a2e;
		text-decoration: none;
	}

	nav ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		gap: 1.5rem;
	}

	nav ul a {
		text-decoration: none;
		color: #4b5563;
		font-size: 0.95rem;
		transition: color 0.2s;
	}

	nav ul a:hover {
		color: #3245ff;
	}

	main {
		max-width: 800px;
		margin: 0 auto;
		padding: 2.5rem 2rem;
	}

	footer {
		text-align: center;
		padding: 2rem;
		color: #9ca3af;
		font-size: 0.85rem;
		border-top: 1px solid #e5e7eb;
		margin-top: 4rem;
	}
</style>
